# Sourced by Claude Code before EVERY Bash command, via CLAUDE_ENV_FILE. On the
# host (the unsandboxed toplevel) .envrc exports CLAUDE_ENV_FILE when you `cd` in;
# inside a worktree's Podman sandbox the launcher (.agent/run) passes the same
# path with `-e CLAUDE_ENV_FILE`. Either way Claude sources ~/.bashrc (your conda
# activation) once at session start and does NOT persist env between commands, so
# the per-worktree venv must be re-applied for each command -- this file does
# that, prepending the venv on top of conda. The literal $PATH below is expanded
# by the shell at source time (after conda is already on PATH), so the venv wins.
# (Claude's settings.json "env" could not do this -- it does not expand ${PATH} --
# which is why this mechanism exists. See README.md Appendix B.)
export VIRTUAL_ENV="{{WORKTREE}}/.venv"
export PATH="{{WORKTREE}}/.venv/bin:$PATH"
export PYTHONSAFEPATH=1
