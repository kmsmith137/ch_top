#!/usr/bin/env python3
"""`git status` across all repos in a top workspace, plus a branch-relation
summary.

    git-status [GIT_STATUS_ARGS...]

Runs `git status` in the workspace root (top / <feature>) and in each
manifest repo subdir (ksgpu, pirate, ...), under a per-repo header. Extra args
are passed through to git, e.g. `git-status -s` or `git-status -sb`.

Then prints, for each repo, how the feature-worktree branch relates to that
repo's integration branch (the one checked out in the main worktree), e.g.
'dev/pirate is 2 commits ahead of top/pirate (kms branch)'; repos already
up-to-date are omitted (a fully up-to-date worktree collapses to one line). Run
from the toplevel top this covers every feature worktree; run from a feature
worktree it covers only that worktree's own branch.

Finally, a 'WARNING:' line (set off by a blank line) is printed for any checkout
that is NOT on its EXPECTED branch -- a toplevel repo off its integration branch,
or a worktree repo off its feature branch. From the toplevel this checks every
worktree; from a worktree, the toplevel repos + this worktree.

Exits with the worst git exit code across the repos.
"""
from __future__ import annotations

import os
import sys

# Make ch_top_helpers importable under PYTHONSAFEPATH=1 (see its module docstring).
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import ch_top_helpers as wl


def main() -> None:
    rc = wl.run_git_all(["status", *sys.argv[1:]])
    relations = wl.branch_relations()
    if relations:
        print("==================== branch relations ====================")
        for line in relations:
            print(line)
        print()
    # Any checkout not on its expected branch -- each on its own 'WARNING:' line,
    # preceded by a blank line so it stands out at the very end of the output.
    for warning in wl.branch_warnings():
        print(f"\n{warning}")
    raise SystemExit(rc)


if __name__ == "__main__":
    main()
