#!/usr/bin/env bash
# sbox-claude -- launch this worktree's coding agent (claude) inside the sandbox.
#
# All the container setup -- mounts, env, network, devices, egress proxy -- lives
# in sbox-common.sh (shared with sbox-shell); this only chooses the command to run.
# Run from a feature worktree: `cd ~/ch/<feature> && ./sbox-claude`. Extra args are
# passed through to claude. See README.md "Sandbox and GPU".
set -euo pipefail
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/sbox-common.sh"

# Run claude in the container; propagate its exit status. $FWD (from
# sbox-common.sh) is the proxy-forwarder prelude for the private-netns mode --
# empty otherwise -- and bash exec's straight into claude either way.
rc=0
podman "${a[@]}" "$IMAGE" \
  bash -c "${FWD}"'exec claude --dangerously-skip-permissions "$@"' claude "$@" || rc=$?
exit "$rc"
